{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@ray/migrate": ["./packages/migrate/src/index.ts"],
      "@ray/plugin-compat": ["./packages/plugin-compat/src/index.ts"],
      "@ray/core": ["./packages/core/src/index.ts"],
      "@ray/dev-server": ["./packages/dev-server/src/index.ts"],
      "@ray/transform": ["./packages/transform/src/index.ts"],
      "@ray/hmr-runtime": ["./packages/hmr-runtime/src/index.ts"],
      "@ray/compiler-rust": ["./packages/compiler-rust/src/index.ts"],
      "@ray/plugin-mdx": ["./packages/plugin-mdx/src/index.ts"],
      "@ray/plugin-analyzer": ["./packages/plugin-analyzer/src/index.ts"],
      "@ray/incremental-build": ["./packages/incremental-build/src/index.ts"],
      "@ray/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "create-ray-plugin": ["./packages/create-ray-plugin/src/cli.ts"],
      "@ray/plugin-registry": ["./packages/plugin-registry/src/index.ts"],
      "@ray/plugin-manager": ["./packages/plugin-manager/src/index.ts"],
      "@ray/language-server": ["./packages/language-server/src/index.ts"],
      "@ray/plugin-svelte": ["./packages/plugin-svelte/src/index.ts"]
    }
  }
}
